# Apache .htaccess для androidchity.ru (статический деплой)
# Кэширование и сжатие для ускорения загрузки

<IfModule mod_headers.c>
  # Кэш для статики: 1 год (immutable)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Кэш для CSS/JS: 1 неделя
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
  # HTML — без долгого кэша
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=60, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# Защита от просмотра директорий
Options -Indexes

# Предотвращение hotlink изображений (опционально, закомментировать если ломает)
